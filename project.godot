; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ya_game"
run/main_scene="uid://f8dl3pbuajrn"
config/features=PackedStringArray("4.5", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/fullsize=false
boot_splash/image="uid://g0oitwqcbrna"
config/icon="res://icon.svg"

[autoload]

WebBus="*res://addons/webbus/webbus.gd"
InitYandexGames="*res://Scripts/Globals/init_yandex_games.gd"
SaveManager="*res://Scripts/Globals/save_manager.gd"
GlobalValues="*res://Scripts/Globals/global_values.gd"
Utils="*res://Scripts/Globals/utils.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=1024
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

movie_writer/ogv/audio_quality=0.0
movie_writer/movie_file="F:/Godot_project_ya_2/ya_game/Movie/1.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/SmoothScroll/plugin.cfg", "res://addons/webbus/plugin.cfg")

[file_customization]

folder_colors={
"res://Misc/": "yellow",
"res://Scripts/": "pink",
"res://Textures2D/": "purple"
}

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 1,
"compress/normal_map": 0,
"detect_3d/compress_to": 1,
"mipmaps/generate": false,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": ""
}

[input]

